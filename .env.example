# Application
APP_NAME="Moto Gia Thinh"
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_DB=motogiathinh
POSTGRES_USER=mgt
POSTGRES_PASSWORD=mgt_secret
DATABASE_URL=postgresql+asyncpg://mgt:mgt_secret@db:5432/motogiathinh

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# MinIO / S3
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
S3_ENDPOINT=http://minio:9000
S3_BUCKET_NAME=motogiathinh
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_secret
S3_USE_SSL=false

# Email (SMTP)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=no-reply@motogiathinh.vn

# SMS (ESMS.vn)
SMS_API_KEY=your-esms-api-key
SMS_API_SECRET=your-esms-api-secret
SMS_SENDER_ID=MotoGThnh

# Facebook Graph API
FB_APP_ID=your-fb-app-id
FB_APP_SECRET=your-fb-app-secret
FB_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
# Map FB Page IDs to branch IDs (JSON): {"page_id_1": "branch_uuid_1"}
FB_PAGE_BRANCH_MAP={}

# Google Vision OCR (optional, fallback to Tesseract)
GOOGLE_VISION_API_KEY=

# diachi.io — old→new Vietnamese address conversion (2025 admin reform).
# Used by POST /api/address/convert (proxied server-side; the CCCD QR carries an
# old address). Leave the key empty for the free tier (~1 batch / 3 min; complex
# merged addresses may be skipped). Set a key (diachi.io "Standard", ~200k VND)
# to lift the throttle. On any upstream failure the endpoint returns the
# originals unchanged (notSure=true), so the add-student flow never breaks.
DIACHI_API_URL=https://diachi.io/api/convert-batch
DIACHI_API_KEY=

# School Info
SCHOOL_NAME=Trường Dạy Lái Xe Moto Gia Thịnh
SCHOOL_ADDRESS=123 Đường ABC, Quận 1, TP.HCM
SCHOOL_PHONE=028-1234-5678
SCHOOL_EMAIL=info@motogiathinh.vn

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]
