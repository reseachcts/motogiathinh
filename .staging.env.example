# Staging VPS credentials
# Copy this file to .staging.env and fill in real values (.staging.env is gitignored)

VPS_HOST=1.2.3.4
VPS_USER=root
VPS_PASS=your-staging-password
VPS_PORT=22
REMOTE_DIR=/opt/motogiathinh

# IMPORTANT: use an absolute URL here — staging serves from raw IP, not same-origin
VITE_API_BASE_URL=http://1.2.3.4/api/v1
